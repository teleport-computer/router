# Server environment variables — example template
# Copy to server/.env and fill in actual values

# ── M2b: Lark Phase 1 ──
LARK_BOT_ENABLED=false
LARK_VERIFICATION_TOKEN=
LARK_SUMMARIZE_MODEL=deepseek/deepseek-chat
LARK_TIME_PARSE_MODEL=deepseek/deepseek-chat
LARK_SUMMARIZE_RATE_LIMIT_MS=300000

# ── Matrix entry mirror ──
# If set, published visible entries mirror once to this Matrix room.
MATRIX_BOT_NOISE_ROOM_ID=
