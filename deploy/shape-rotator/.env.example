# Shape Rotator instance — server-side env template
# Copy to server/.env.shape and fill in placeholders. The ecosystem.config.cjs
# loads this via Node 20.6+ `node --env-file=.env.shape ...`.
#
# Local dev:        cd server && npm run dev:shape
# Production (EC2): pm2 reload ecosystem.config.cjs --update-env

# ── Server / DB ──
# 4002 = shape-server internal port. The PUBLIC URL points at 4001 because
# users hit shape-web (which proxies /api/* to the server on 4002).
PORT=4002
DATABASE_URL=postgresql://USER:PASS@HOST:5432/router_shape?sslmode=no-verify
PUBLIC_URL=http://YOUR_DOMAIN_OR_IP:4001

# Used by the server's CORS allow-list. Same value as PUBLIC_URL is correct
# unless you have other origins (e.g. a separate Hermes agent host) calling
# in with cookies. Comma-separated.
ALLOWED_ORIGINS=http://YOUR_DOMAIN_OR_IP:4001

# ── LLM ──
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── Behavior ──
STAGING_DELAY_MS=900000  # 15 min entry-staging window

# ── Matrix onboarding/linking ──
# Comma-separated private Router handles allowed to create Matrix link codes
# and provision Matrix-first Router accounts. Team admins are always allowed.
MATRIX_LINK_SERVICE_HANDLES=testbot

# ── Matrix sparks ──
# Automatic spark evaluation on published entries. Manual spark search/trigger
# tools are available without this flag; automatic execution requires it.
SPARKS_ENABLED=false
# Comma-separated non-admin Router handles allowed to manually trigger sparks.
SPARK_MODERATOR_HANDLES=
# Preferred: point at an E2EE-capable Matrix bridge service for room creation,
# DMs, spark-room state, and recent-message debounce checks.
# Production deploys fail closed unless these are set.
MATRIX_SPARK_SERVICE_URL=
MATRIX_SPARK_SERVICE_KEY=
# Fallback direct Matrix Client-Server API mode.
MATRIX_HOMESERVER=https://mtrx.shaperotator.xyz
MATRIX_ACCESS_TOKEN=
# Published visible Router entries are mirrored once to this Matrix room.
MATRIX_BOT_NOISE_ROOM_ID=

# ── Feature flags (env-driven, gate web UI surfaces) ──
LARK_BOT_ENABLED=false   # → features.platforms excludes "lark" → Lark UI hidden
LOCALES_AVAILABLE=en     # → features.languages = ["en"] → language toggle hidden

# ── Cookies / TLS ──
# 0 = HTTP-only deployment (no TLS). Set to 1 once you put TLS in front.
COOKIE_SECURE=0

# ── Production marker ──
# Triggers requireEnv() fail-fast on missing PUBLIC_URL. Don't set on dev.
NODE_ENV=production

# ── Local dev override (uncomment for cd server && npm run dev:shape) ──
# PORT=4001
# DATABASE_URL=postgresql://localhost:5432/router_shape
# PUBLIC_URL=http://localhost:4000
# COOKIE_SECURE=0
# # leave NODE_ENV unset
